        <defaultConnectorLabel>Other Title</defaultConnectorLabel>
        <rules>
            <name>Decision_Maker_Title</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Title</leftValueReference>
                <operator>Contains</operator>
