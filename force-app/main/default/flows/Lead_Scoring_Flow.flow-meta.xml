        <locationX>176</locationX>
        <locationY>1106</locationY>
        <defaultConnector>
            <targetReference>Check_Title</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Generic Email</defaultConnectorLabel>
        <rules>
            <name>Corporate_Email</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Email</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Email</leftValueReference>
                <operator>NotContain</operator>
                <rightValue>
                    <stringValue>@gmail.com</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Email</leftValueReference>
                <operator>NotContain</operator>
                <rightValue>
                    <stringValue>@yahoo.com</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Email</leftValueReference>
                <operator>NotContain</operator>
                <rightValue>
                    <stringValue>@hotmail.com</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Add_Email_Domain_Score</targetReference>
            </connector>
            <label>Corporate Email</label>
        </rules>
    </decisions>
