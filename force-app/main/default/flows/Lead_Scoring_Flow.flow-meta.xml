    <decisions>
        <name>Determine_Lead_Grade</name>
        <label>Determine Lead Grade</label>
        <locationX>176</locationX>
        <locationY>1646</locationY>
        <defaultConnector>
            <targetReference>Set_Grade_C</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Score 0-40 (Grade C)</defaultConnectorLabel>
        <rules>
            <name>Score_60_Plus</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varLeadScore</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <numberValue>60.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Grade_A</targetReference>
            </connector>
            <label>Score 60+ (Grade A)</label>
        </rules>
        <rules>
            <name>Score_41_59</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varLeadScore</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <numberValue>41.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>varLeadScore</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <numberValue>60.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Grade_B</targetReference>
            </connector>
            <label>Score 41-59 (Grade B)</label>
        </rules>
    </decisions>
    <description>Automatically scores leads based on multiple criteria including company size, revenue, industry, lead source, email domain, and title. Assigns a grade (A-Hot, B-Warm, C-Cold) based on the total score.</description>
